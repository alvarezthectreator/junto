# Server Configuration
PORT=5000
NODE_ENV=development
API_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173
DB_PATH=./junto.db
UPLOAD_STORAGE_DIR=./uploads
UPLOAD_PUBLIC_PATH=/uploads
SESSION_TIMEOUT_MS=3600000
LOG_LEVEL=info
ENABLE_MONITORING=false

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=junto_db
DB_USER=junto_user
DB_PASSWORD=junto_password_dev

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ZeptoMail API configuration
ZEPTOMAIL_HOST=api.zeptomail.com
ZEPTOMAIL_SEND_MAIL_TOKEN=your-zeptomail-send-mail-token
ZEPTOMAIL_FROM=no-reply@wantuu.com
ZEPTOMAIL_FROM_NAME=Wantuu

# OTP Configuration
OTP_EXPIRY_MINUTES=5
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=3
OTP_MAX_REQUESTS_PER_HOUR=5

# Feature Flags
MOCK_DATA=true
ADMIN_SETUP_KEY=mysecret123
