# Server Configuration
PORT=5000
NODE_ENV=development
API_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173
DB_PATH=./junto.db

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=junto_db
DB_USER=junto_user
DB_PASSWORD=junto_password_dev

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d

# SMTP Email Configuration (for OTP Authentication)
# Railway production should use these variables
SMTP_HOST=mail.orquex.com
SMTP_PORT=465
SMTP_USER=testmail@orquex.com
SMTP_PASSWORD=replace-me
SMTP_FROM=testmail@orquex.com
SMTP_SECURE=true
SMTP_REQUIRE_TLS=false

# OTP Configuration
OTP_EXPIRY_MINUTES=5
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=3
OTP_MAX_REQUESTS_PER_HOUR=5

# Feature Flags
MOCK_DATA=true
