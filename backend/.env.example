# Server Configuration
PORT=5000
NODE_ENV=development
API_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=junto_db
DB_USER=junto_user
DB_PASSWORD=junto_password_dev

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d

# cPanel Email Configuration (for OTP Authentication)
# These are required for OTP to work
CPANEL_EMAIL_HOST=mail.orquex.com
CPANEL_EMAIL_PORT=465
CPANEL_EMAIL_USER=testmail@orquex.com
CPANEL_EMAIL_PASSWORD=100000000
CPANEL_EMAIL_FROM=testmail@orquex.com

# OTP Configuration
OTP_EXPIRY_MINUTES=5
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=3
OTP_MAX_REQUESTS_PER_HOUR=5

# Feature Flags
MOCK_DATA=true

